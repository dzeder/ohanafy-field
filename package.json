{
  "name": "ohanafy-field",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "expo start",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ app/ --ext .ts,.tsx --max-warnings 0",
    "format": "prettier --write 'src/**/*.{ts,tsx}' 'app/**/*.{ts,tsx}'"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@nozbe/watermelondb": "^0.27.1",
    "@react-native-community/netinfo": "11.4.1",
    "@react-native-voice/voice": "^3.2.4",
    "@sentry/react-native": "~6.10.0",
    "@shopify/flash-list": "1.7.6",
    "@tanstack/react-query": "^5.62.7",
    "expo": "^52.0.0",
    "expo-auth-session": "~6.0.3",
    "expo-background-fetch": "~13.0.5",
    "expo-build-properties": "~0.13.2",
    "expo-constants": "~17.0.6",
    "expo-crypto": "~14.0.2",
    "expo-linking": "~7.0.5",
    "expo-local-authentication": "~15.0.2",
    "expo-notifications": "~0.29.13",
    "expo-router": "~4.0.17",
    "expo-secure-store": "~14.0.1",
    "expo-splash-screen": "~0.29.21",
    "expo-status-bar": "~2.0.1",
    "expo-system-ui": "~4.0.7",
    "expo-task-manager": "~12.0.5",
    "expo-web-browser": "~14.0.2",
    "nativewind": "^4.1.23",
    "posthog-react-native": "^3.5.4",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.5",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-get-random-values": "~1.11.0",
    "react-native-reanimated": "^3.15.5",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-web": "~0.19.13",
    "tailwindcss": "^3.4.17",
    "zod": "^3.24.1",
    "zod-to-json-schema": "^3.25.2",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.9.0",
    "@types/jest": "^29.5.14",
    "@types/react": "~18.3.12",
    "@types/react-test-renderer": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "ajv": "^8.20.0",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-native": "^4.1.0",
    "jest": "^29.7.0",
    "jest-expo": "~52.0.2",
    "prettier": "^3.4.2",
    "react-test-renderer": "18.3.1",
    "typescript": "^5.7.2"
  },
  "private": true,
  "jest": {
    "preset": "jest-expo",
    "setupFiles": [
      "./jest.setup.js"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!(@react-native|react-native|expo|expo-modules-core|expo-router|@expo|@nozbe/watermelondb|@sentry/react-native|posthog-react-native|nativewind))"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    },
    "modulePathIgnorePatterns": [
      "<rootDir>/references/",
      "<rootDir>/scripts/sf-bootstrap/",
      "<rootDir>/.expo/"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/references/",
      "/scripts/sf-bootstrap/",
      "/.expo/"
    ],
    "collectCoverageFrom": [
      "src/**/*.{ts,tsx}",
      "!src/**/*.d.ts"
    ]
  }
}
